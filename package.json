{
    "name": "@ds-ukassel/yaml-ls-check",
    "version": "2.0.0",
    "description": "Library and tool used to validate YAML files against one or more schemas utilizing the yaml-language-server project.",
    "license": "MIT",
    "author": "Distributed Systems Group, University of Kassel",
    "homepage": "https://github.com/ds-ukassel/yaml-ls-check#readme",
    "bugs": {
        "url": "https://github.com/ds-ukassel/yaml-ls-check/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ds-ukassel/yaml-ls-check.git"
    },
    "keywords": [
        "yaml",
        "validate",
        "schema",
        "yaml-language-server",
        "vscode"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "yaml-ls-check": "dist/cli.js",
        "ylsc": "dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "start": "ts-node src/cli.ts",
        "clean": "rimraf dist",
        "build:lib": "tsc",
        "build:action": "node esbuild.config.mjs",
        "build": "npm-run-all clean build:lib build:action",
        "format": "prettier --write '**/*.ts'",
        "lint": "prettier --check '**/*.ts'",
        "test": "jest"
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^24.12.0",
        "esbuild": "^0.27.4",
        "jest": "^30.3.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@actions/core": "^3.0.0",
        "commander": "^14.0.3",
        "extensionless": "^2.0.6",
        "glob": "^13.0.6",
        "jsonc-parser": "^3.3.1",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0",
        "vscode-json-languageservice": "4.1.8",
        "vscode-languageserver-textdocument": "^1.0.12",
        "vscode-languageserver-types": "^3.17.5",
        "vscode-uri": "^3.1.0",
        "yaml-language-server": "^1.21.0"
    },
    "resolutions": {
        "lodash@^4": "^4.17.23"
    }
}
